# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://user:password@localhost:27017/edumarket?authSource=admin

# ── JWT (generate with: openssl rand -base64 64) ────────────────────────────
JWT_ACCESS_SECRET=change_me_min_32_chars_random_string
JWT_REFRESH_SECRET=change_me_min_32_chars_different_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Bunny.net Stream ──────────────────────────────────────────────────────────
BUNNY_STREAM_API_KEY=your_bunny_stream_api_key
BUNNY_STREAM_LIBRARY_ID=your_library_id
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
BUNNY_TOKEN_AUTHENTICATION_KEY=your_token_authentication_key

# ── Bunny.net Storage (thumbnails) ────────────────────────────────────────────
BUNNY_STORAGE_API_KEY=your_storage_api_key
BUNNY_STORAGE_ZONE_NAME=your_zone_name
BUNNY_STORAGE_CDN_URL=https://your-zone.b-cdn.net

# ── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="EduMarket <noreply@edumarket.ro>"
CONTACT_EMAIL=admin@edumarket.ro
